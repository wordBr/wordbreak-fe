# WordBreak web config. Copy to .env.local for dev.

# Backend (Go) URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# Chain — defaults target Celo Sepolia testnet.
#   Celo Sepolia: 11142220  (https://forno.celo-sepolia.celo-testnet.org)
#   Celo mainnet: 42220     (https://forno.celo.org)
NEXT_PUBLIC_CHAIN_ID=11142220
NEXT_PUBLIC_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Deployed contracts (required for the daily pool). Without these, /daily shows "no pool".
NEXT_PUBLIC_POOLS_ADDRESS=
NEXT_PUBLIC_CUSD_ADDRESS=

# Optional: pay gas in cUSD on mainnet MiniPay (CIP-64). Leave empty on testnet.
#   Mainnet cUSD: 0x765DE816845861e75A25fCA122bb6898B8B1282a
NEXT_PUBLIC_FEE_CURRENCY=

# WalletConnect Cloud project ID, passed through to Privy for QR-pairing to mobile wallets.
# Get one from https://dashboard.walletconnect.com. Unset = that pairing path is inert.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Privy (email/social login + embedded wallet). Get an App ID from https://dashboard.privy.io
# -- this is the public client ID, safe to expose. Do NOT put Privy's app *secret* here or
# anywhere in the frontend; it's a server-side key this project doesn't use.
NEXT_PUBLIC_PRIVY_APP_ID=